{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-05-17",
  "name": "skland-daily-attendance",
  "compatibility_flags": ["nodejs_als"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "KV","id": "8d26a5127dcc4a5db96fc45f79178edb"
    }
  ],
  "triggers": {
    "crons": ["30 */2 * * *"]
  }
}
